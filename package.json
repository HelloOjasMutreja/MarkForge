{
  "name": "markforge",
  "private": false,
  "version": "0.1.0",
  "description": "Desktop Markdown editor with multi-format export for Windows and Linux.",
  "author": "Ojas Mutreja",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:web": "vite",
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build:web": "tsc -b && vite build",
    "build": "npm run build:web && electron-builder",
    "pack": "npm run build:web && electron-builder --dir",
    "dist:win": "npm run build:web && electron-builder --win nsis",
    "dist:linux": "npm run build:web && electron-builder --linux AppImage deb",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "dompurify": "^3.4.1",
    "markdown-it": "^14.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.markforge.desktop",
    "productName": "MarkForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "MarkForge-${version}-Windows-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "artifactName": "MarkForge-${version}-Linux-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
